# PandaDoc API (get from AWS Secrets Manager: aspire/dev/pandadoc)
PANDADOC_API_KEY=your_pandadoc_api_key_here
PANDADOC_CREDENTIAL_LAST_ROTATED=2026-01-01

# Supabase (get from AWS Secrets Manager: aspire/dev/supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenAI (get from AWS Secrets Manager: aspire/dev/openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Twilio (get from AWS Secrets Manager: aspire/dev/twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Stripe (get from AWS Secrets Manager: aspire/dev/stripe)
STRIPE_API_KEY=your_stripe_api_key_here

# Internal
ENVIRONMENT=development
LOG_LEVEL=INFO

# Browser Automation (Hybrid Browser View — Wave 1-4)
BROWSER_DOMAIN_ALLOWLIST=bing.com,google.com,wikipedia.org,duckduckgo.com
BROWSER_SCREENSHOT_S3_BUCKET=aspire-screenshots
