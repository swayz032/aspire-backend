{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aspire.local/schemas/robot-run.json",
  "title": "RobotRun",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "env",
    "suite",
    "status",
    "startedAt",
    "versionRef",
    "scenarios"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 8
    },
    "env": {
      "type": "string",
      "enum": [
        "staging",
        "canary",
        "production"
      ]
    },
    "suite": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "partial"
      ]
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "versionRef": {
      "type": "string",
      "minLength": 1
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status",
          "summary",
          "evidence"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "partial"
            ]
          },
          "summary": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "dir": {
          "type": "string"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
