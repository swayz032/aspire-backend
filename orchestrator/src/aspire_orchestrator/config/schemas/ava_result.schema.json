{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AvaResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "outputs"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "retryable_error",
        "fatal_error"
      ]
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correlation_id",
        "route",
        "risk",
        "governance",
        "plan"
      ],
      "properties": {
        "correlation_id": {
          "type": "string",
          "minLength": 1
        },
        "route": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "skillpack_id",
            "confidence",
            "reason_codes"
          ],
          "properties": {
            "skillpack_id": {
              "type": "string",
              "minLength": 1
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "reason_codes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            }
          }
        },
        "risk": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tier",
            "required_presence"
          ],
          "properties": {
            "tier": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "red"
              ]
            },
            "required_presence": {
              "type": "string",
              "enum": [
                "none",
                "ava_voice",
                "ava_video"
              ]
            }
          }
        },
        "governance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "approval_required",
            "approval_reason_codes",
            "policy_version",
            "tool_policy_version",
            "requested_tools",
            "allowed_tools",
            "payload_hash"
          ],
          "properties": {
            "approval_required": {
              "type": "boolean"
            },
            "approval_reason_codes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "policy_version": {
              "type": "string",
              "minLength": 1
            },
            "tool_policy_version": {
              "type": "string",
              "minLength": 1
            },
            "requested_tools": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "allowed_tools": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "payload_hash": {
              "type": "string",
              "minLength": 32
            }
          }
        },
        "plan": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "steps",
            "blockers"
          ],
          "properties": {
            "steps": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            },
            "blockers": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "outbox_jobs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "action_type",
              "provider",
              "inputs",
              "requires_approval"
            ],
            "properties": {
              "action_type": {
                "type": "string",
                "minLength": 1
              },
              "provider": {
                "type": "string",
                "minLength": 1
              },
              "inputs": {
                "type": "object",
                "additionalProperties": true
              },
              "requires_approval": {
                "type": "boolean"
              },
              "idempotency_key": {
                "type": "string"
              }
            }
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "tool_receipts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "tool_name",
          "tool_call_id",
          "started_at",
          "finished_at"
        ],
        "properties": {
          "tool_name": {
            "type": "string",
            "minLength": 1
          },
          "tool_call_id": {
            "type": "string",
            "minLength": 1
          },
          "started_at": {
            "type": "string",
            "minLength": 1
          },
          "finished_at": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "error"
            ]
          },
          "error": {
            "type": "string"
          }
        }
      }
    }
  }
}
