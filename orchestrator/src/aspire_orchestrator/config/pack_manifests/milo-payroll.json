{
  "skillpack_id": "milo-payroll",
  "name": "Milo Payroll",
  "agent_name": "Milo",
  "channel": "internal_frontend",
  "version": "3.0.0",
  "description": "Payroll processing, tax calculation verification, Gusto integration. RED tier — requires dual approval.",
  "capabilities": [
    "can_plan_payroll_run",
    "can_verify_tax_calculations",
    "can_generate_payroll_snapshot",
    "can_track_payroll_deadlines"
