    "gusto.payroll.run",
    "gusto.read_payrolls"
  ],
  "providers": ["gusto"],
  "actions": [
    "payroll.run", "payroll.snapshot", "payroll.schedule", "payroll.deadline"
  ],
  "certification_status": "uncertified",
  "outputs": ["payroll_plan", "payroll_snapshot", "tax_verification"],
  "dependencies": []
}
