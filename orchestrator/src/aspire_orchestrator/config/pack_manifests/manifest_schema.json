{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aspireos.app/schemas/pack_manifest.v1.json",
  "title": "Aspire Skill Pack Manifest",
  "description": "Defines a skill pack's identity, capabilities, risk profile, and certification status. Ported from PHASE_3_SKILL_PACKS_CERTIFICATION/TEMPLATES/PACK_MANIFEST_TEMPLATE.json.",
  "type": "object",
  "required": ["skillpack_id", "name", "version"],
  "properties": {
    "skillpack_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for the skill pack (e.g., 'adam-research')"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable name (e.g., 'Adam Research')"
    },
    "channel": {
      "type": "string",
      "enum": ["internal_frontend", "external", "internal_backend"],
      "description": "Communication channel: internal_frontend (via Ava), external (user-facing), internal_backend (system)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (e.g., '1.0.0')"
    },
    "description": {
      "type": "string",
      "description": "Brief description of the skill pack's purpose"
    },
    "agent_name": {
      "type": "string",
      "description": "The agent persona name (e.g., 'Adam', 'Quinn', 'Finn')"
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of capability strings (e.g., 'can_search_web', 'can_generate_vendor_outreach_packets')"
    },
    "risk_profile": {
      "type": "object",
      "properties": {
        "default_risk_tier": {
          "type": "string",
          "enum": ["green", "yellow", "red"],
          "description": "Default risk tier for most operations"
        },
        "max_risk_tier": {
          "type": "string",
          "enum": ["green", "yellow", "red"],
          "description": "Maximum risk tier this pack can handle"
        }
      }
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tool IDs this pack is authorized to use"
    },
    "providers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "External provider integrations (e.g., 'stripe', 'moov', 'plaid')"
    },
    "actions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Policy matrix actions this pack handles"
    },
    "certification_status": {
      "type": "string",
      "enum": ["uncertified", "certified", "revoked"],
      "description": "Current certification status"
    },
    "certification_date": {
      "type": "string",
      "format": "date",
      "description": "Date of last certification"
    },
    "outputs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Output types this pack can produce"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Other skill pack IDs this pack depends on"
    }
  },
  "additionalProperties": true
}
