{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "event_type",
    "trace_id",
    "run_id",
    "span_id",
    "suite_id",
    "item_id",
    "task_type",
    "created_at"
  ],
  "properties": {
    "event_type": {
      "const": "a2a.item.created"
    },
    "trace_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "suite_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "item_id": {
      "type": "string"
    },
    "task_type": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "URGENT"
      ]
    },
    "payload": {
      "type": "object"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}