{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "event_type",
    "trace_id",
    "run_id",
    "span_id",
    "suite_id",
    "job_id",
    "status",
    "completed_at"
  ],
  "properties": {
    "event_type": {
      "const": "outbox.job.completed"
    },
    "trace_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "suite_id": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "SUCCEEDED",
        "FAILED"
      ]
    },
    "provider": {
      "type": "string"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}