{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "$ref": "./receipt.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "receipt_type": {
          "const": "money.transfer.executed"
        },
        "authority_item_id": {
          "type": "string"
        },
        "outbox_job_id": {
          "type": "string"
        },
        "provider": {
          "type": "string",
          "enum": [
            "plaid_transfer"
          ]
        },
        "provider_transfer_id": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "amount_cents": {
          "type": "integer"
        },
        "currency": {
          "type": "string"
        }
      },
      "required": [
        "receipt_type",
        "authority_item_id",
        "outbox_job_id",
        "provider",
        "provider_transfer_id",
        "status"
      ]
    }
  ]
}