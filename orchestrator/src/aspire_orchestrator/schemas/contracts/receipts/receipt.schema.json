{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "receipt_id",
    "receipt_type",
    "trace_id",
    "run_id",
    "span_id",
    "suite_id",
    "created_at",
    "hash"
  ],
  "properties": {
    "receipt_id": {
      "type": "string"
    },
    "receipt_type": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "suite_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "actor": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "system"
          ]
        },
        "id": {
          "type": "string"
        }
      }
    },
    "action_type": {
      "type": "string"
    },
    "inputs_redacted": {
      "type": "object"
    },
    "policy_decision_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "approval_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "provider_call_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outcome": {
      "type": [
        "object",
        "null"
      ]
    },
    "hash": {
      "type": "string"
    },
    "signature": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "office_id": {
      "type": "string",
      "description": "Office/seat identifier within suite_id (team member)."
    }
  }
}