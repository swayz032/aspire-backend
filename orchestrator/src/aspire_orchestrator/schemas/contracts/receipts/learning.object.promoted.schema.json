{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "learning.object.promoted",
  "description": "A learning object or configuration was promoted after canary.",
  "allOf": [
    {
      "$ref": "./receipt.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "receipt_type": {
          "const": "learning.object.promoted"
        },
        "office_id": {
          "type": "string"
        },
        "object_kind": {
          "type": "string"
        },
        "object_id": {
          "type": "string"
        },
        "rollout_id": {
          "type": "string"
        }
      },
      "required": [
        "receipt_type",
        "office_id",
        "object_kind",
        "object_id",
        "rollout_id"
      ]
    }
  ]
}