{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "learning.runbook",
  "type": "object",
  "required": [
    "id",
    "title",
    "suite_scope",
    "tags",
    "steps",
    "signals",
    "rollback",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "suite_scope": {
      "type": "string",
      "enum": [
        "global_deidentified",
        "suite_scoped"
      ]
    },
    "suite_id": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "rollback": {
      "type": "string"
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string"
    }
  }
}