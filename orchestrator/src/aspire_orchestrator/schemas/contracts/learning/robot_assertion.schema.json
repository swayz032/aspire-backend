{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "learning.robot_assertion",
  "type": "object",
  "required": [
    "id",
    "journey",
    "assertions",
    "tags",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "journey": {
      "type": "string"
    },
    "assertions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string"
    }
  }
}