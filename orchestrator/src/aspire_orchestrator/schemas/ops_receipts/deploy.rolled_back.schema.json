{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "deploy.rolled_back",
  "description": "Deployment rolled back.",
  "allOf": [
    {
      "$ref": "./receipt.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "receipt_type": {
          "const": "deploy.rolled_back"
        },
        "office_id": {
          "type": "string"
        },
        "trace_id": {
          "type": "string"
        },
        "release_id": {
          "type": "string"
        },
        "environment": {
          "type": "string",
          "enum": [
            "dev",
            "staging",
            "prod"
          ]
        },
        "reason": {
          "type": "string"
        },
        "rollback_release_id": {
          "type": "string"
        },
        "metrics_snapshot_ref": {
          "type": "string"
        }
      },
      "required": [
        "receipt_type",
        "office_id",
        "trace_id",
        "release_id",
        "environment",
        "reason"
      ]
    }
  ]
}