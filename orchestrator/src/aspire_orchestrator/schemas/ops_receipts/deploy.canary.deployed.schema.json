{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "deploy.canary.deployed",
  "description": "Canary deployed for a release.",
  "allOf": [
    {
      "$ref": "./receipt.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "receipt_type": {
          "const": "deploy.canary.deployed"
        },
        "office_id": {
          "type": "string"
        },
        "trace_id": {
          "type": "string"
        },
        "release_id": {
          "type": "string"
        },
        "environment": {
          "type": "string",
          "enum": [
            "dev",
            "staging",
            "prod"
          ]
        },
        "canary_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "metrics_snapshot_ref": {
          "type": "string"
        }
      },
      "required": [
        "receipt_type",
        "office_id",
        "trace_id",
        "release_id",
        "environment",
        "canary_percent"
      ]
    }
  ]
}