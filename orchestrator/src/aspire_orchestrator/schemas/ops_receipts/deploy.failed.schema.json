{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "deploy.failed",
  "description": "Deployment failed before completion.",
  "allOf": [
    {
      "$ref": "./receipt.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "receipt_type": {
          "const": "deploy.failed"
        },
        "office_id": {
          "type": "string"
        },
        "trace_id": {
          "type": "string"
        },
        "release_id": {
          "type": "string"
        },
        "environment": {
          "type": "string",
          "enum": [
            "dev",
            "staging",
            "prod"
          ]
        },
        "error": {
          "type": "string"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "receipt_type",
        "office_id",
        "trace_id",
        "release_id",
        "environment",
        "error"
      ]
    }
  ]
}