{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "restore.tested",
  "description": "Restore test completed.",
  "allOf": [
    {
      "$ref": "./receipt.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "receipt_type": {
          "const": "restore.tested"
        },
        "office_id": {
          "type": "string"
        },
        "trace_id": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "success",
            "fail"
          ]
        },
        "artifact_ref": {
          "type": "string"
        },
        "rto_minutes": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "receipt_type",
        "office_id",
        "trace_id",
        "target",
        "status",
        "artifact_ref"
      ]
    }
  ]
}