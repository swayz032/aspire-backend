        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "(sum by (provider) (rate(provider_calls_total{status=\"failure\"}[5m])) / sum by (provider) (rate(provider_calls_total[5m]))) * 100",
          "legendFormat": "{{provider}}",
          "refId": "A"
