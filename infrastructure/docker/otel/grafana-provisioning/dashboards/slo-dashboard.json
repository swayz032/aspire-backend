{
  "title": "Aspire SLO Dashboard",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "uid": "aspire-slo-v1",
  "panels": [
    {
      "type": "timeseries",
      "title": "Outbox Queue Depth",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "aspire_outbox_oldest_pending_age_seconds",
          "legendFormat": "{{instance}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Executor Errors",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(aspire_executor_errors_total[5m])",
          "legendFormat": "{{error_type}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Approval Latency (p95)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(aspire_approval_latency_seconds_bucket[15m]))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
    }
  ]
}
