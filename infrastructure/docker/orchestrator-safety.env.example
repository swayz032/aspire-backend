ASPIRE_ENV=production
NODE_ENV=production

# Safety gateway
ASPIRE_SAFETY_GATEWAY_MODE=nemo
ASPIRE_SAFETY_GATEWAY_API_KEY=replace-with-long-random-shared-secret
ASPIRE_SAFETY_GATEWAY_SHARED_SECRET=replace-with-same-long-random-shared-secret
ASPIRE_SAFETY_GATEWAY_TIMEOUT_SECONDS=5

# Orchestrator core
ASPIRE_ADMIN_JWT_SECRET=replace-with-long-random-admin-jwt-secret
ASPIRE_ROBOT_S2S_SECRET=replace-with-long-random-robot-s2s-secret
ASPIRE_TOKEN_SIGNING_KEY=replace-with-32-byte-min-signing-key
ASPIRE_OPENAI_BASE_URL=https://api.openai.com/v1
ASPIRE_SUPABASE_URL=https://your-project.supabase.co
ASPIRE_SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# LangGraph persistence - production should use postgres
ASPIRE_LANGGRAPH_CHECKPOINTER=postgres
ASPIRE_LANGGRAPH_POSTGRES_DSN=postgresql://postgres:password@db.example.internal:5432/postgres

# Shared runtime infra
ASPIRE_REDIS_URL=redis://redis.example.internal:6379/0

# OpenAI key contract:
# - Set OPENAI_API_KEY server-side (AWS/Railway secret store).
# - Compose mirrors this into ASPIRE_OPENAI_API_KEY for legacy compatibility.
OPENAI_API_KEY=replace-with-openai-key

# Optional provider and gateway settings
ASPIRE_GATEWAY_URL=https://your-gateway.example.com
ASPIRE_POLICY_EVAL_URL=

# Optional runtime hardening
ASPIRE_CREDENTIAL_STRICT_MODE=true
ASPIRE_METRICS_TOKEN=replace-with-long-random-metrics-token
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Optional dedicated incident ingest secret for desktop/gateway reporters.
# If left unset, internal reporters may fall back to other S2S secrets.
ASPIRE_ADMIN_INCIDENT_S2S_SECRET=replace-with-long-random-shared-secret

# Optional Sentry API sync for Admin summaries + deep links
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECTS=ava-brain-backend,admin-portal-web,aspire-desktop-server,aspire-desktop-client
SENTRY_PROJECT_BACKEND=ava-brain-backend
SENTRY_PROJECT_ADMIN_PORTAL=admin-portal-web
SENTRY_PROJECT_DESKTOP_SERVER=aspire-desktop-server
SENTRY_PROJECT_DESKTOP_CLIENT=aspire-desktop-client
SENTRY_AUTH_TOKEN=replace-with-sentry-api-token
SENTRY_BASE_URL=https://sentry.io
