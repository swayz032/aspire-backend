{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "entitlement.seat.added",
  "description": "Seat (office) added to suite.",
  "allOf": [
    {
      "$ref": "./receipt.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "receipt_type": {
          "const": "entitlement.seat.added"
        },
        "office_id": {
          "type": "string"
        },
        "trace_id": {
          "type": "string"
        },
        "suite_id": {
          "type": "string"
        },
        "office_added": {
          "type": "string"
        },
        "new_seat_count": {
          "type": "integer",
          "minimum": 1
        },
        "billing_provider_ref": {
          "type": "string"
        }
      },
      "required": [
        "receipt_type",
        "office_id",
        "trace_id",
        "suite_id",
        "office_added",
        "new_seat_count"
      ]
    }
  ]
}