{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "entitlement.grace.ended",
  "description": "Grace period ended.",
  "allOf": [
    {
      "$ref": "./receipt.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "receipt_type": {
          "const": "entitlement.grace.ended"
        },
        "office_id": {
          "type": "string"
        },
        "trace_id": {
          "type": "string"
        },
        "suite_id": {
          "type": "string"
        },
        "ended_at": {
          "type": "string"
        }
      },
      "required": [
        "receipt_type",
        "office_id",
        "trace_id",
        "suite_id",
        "ended_at"
      ]
    }
  ]
}